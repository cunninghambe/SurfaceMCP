{
  "name": "surfacemcp",
  "version": "0.3.1",
  "private": true,
  "description": "HTTP MCP server exposing a typed, introspectable, role-aware API surface for any target app",
  "type": "module",
  "bin": {
    "surfacemcp": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-runtime-enum.mjs",
    "start": "node dist/server/http.js",
    "dev": "tsx watch src/server/http.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chokidar": "4.0.3",
    "dotenv": "16.6.1",
    "express": "5.2.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "ts-morph": "24.0.0",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
